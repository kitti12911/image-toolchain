{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended"],
    "timezone": "Asia/Bangkok",
    "schedule": ["* 0-4 1 * *"],
    "updateNotScheduled": false,
    "enabledManagers": ["dockerfile", "github-actions", "custom.regex"],
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update Go tool versions installed in Dockerfiles",
            "managerFilePatterns": ["/(^|/)Dockerfile$/"],
            "matchStrings": [
                "go install (?<depName>[^\\s@]+)@(?<currentValue>v?\\d+\\.\\d+\\.\\d+(?:[-+][^\\s\\\\]+)?)"
            ],
            "datasourceTemplate": "go"
        },
        {
            "customType": "regex",
            "description": "Update Python tool versions installed in Dockerfiles",
            "managerFilePatterns": ["/(^|/)Dockerfile$/"],
            "matchStrings": [
                "pip install [^\\n]*?(?<depName>[A-Za-z0-9_.-]+)==(?<currentValue>\\d+\\.\\d+\\.\\d+(?:[-+][^\\s\\\\]+)?)"
            ],
            "datasourceTemplate": "pypi"
        },
        {
            "customType": "regex",
            "description": "Update npm tool versions installed in Dockerfiles",
            "managerFilePatterns": ["/(^|/)Dockerfile$/"],
            "matchStrings": [
                "(?<depName>(?:@?[A-Za-z0-9_.-]+/)?[A-Za-z0-9_.-]+)@(?<currentValue>\\d+\\.\\d+\\.\\d+(?:[-+][^\\s\\\\]+)?)"
            ],
            "datasourceTemplate": "npm"
        },
        {
            "customType": "regex",
            "description": "Update Helm direct downloads in Dockerfiles",
            "managerFilePatterns": ["/(^|/)Dockerfile$/"],
            "matchStrings": ["helm-v(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
            "depNameTemplate": "helm/helm",
            "datasourceTemplate": "github-releases"
        },
        {
            "customType": "regex",
            "description": "Update Trivy direct downloads in Dockerfiles",
            "managerFilePatterns": ["/(^|/)Dockerfile$/"],
            "matchStrings": [
                "aquasecurity/trivy/releases/download/v(?<currentValue>\\d+\\.\\d+\\.\\d+)/"
            ],
            "depNameTemplate": "aquasecurity/trivy",
            "datasourceTemplate": "github-releases"
        }
    ],
    "reviewersFromCodeOwners": true,
    "assigneesFromCodeOwners": true,
    "assignAutomerge": true
}
